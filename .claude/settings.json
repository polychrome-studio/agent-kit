{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/journal-breadcrumb.sh\"",
            "timeout": 15,
            "statusMessage": "Journaling commit…"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/codemap-refresh.sh\"",
            "timeout": 35,
            "statusMessage": "Refreshing code map…"
          }
        ]
      }
    ]
  }
}
